# CSLogbook Production - Template
# Copy เป็น .env.production แล้วแก้ไขค่าตาม VPS ของคุณ
# cp .env.production.example .env.production

BACKEND_PORT=5000
FRONTEND_PORT=3000

# MySQL (ใน Docker)
MYSQL_ROOT_PASSWORD=CHANGE_ME
DB_HOST=mysql
DB_PORT=3306
DB_NAME=cslogbook_prod
DB_USER=root
DB_PASSWORD=CHANGE_ME

# URLs - ผ่าน Nginx port 80 (ไม่มี port ใน URL)
BASE_URL=http://119.59.124.67
FRONTEND_URL=http://119.59.124.67
PORT=5000

# JWT (ต้องอย่างน้อย 32 ตัวอักษร)
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=7d
UPLOAD_DIR=uploads/
MAX_FILE_SIZE=5242880
LOG_ENABLE_CONSOLE=false

# Email
EMAIL_PROVIDER=smtp
EMAIL_SENDER=your-email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Feature Flags
EMAIL_LOGIN_ENABLED=true
EMAIL_DOCUMENT_ENABLED=true
EMAIL_LOGBOOK_ENABLED=true
EMAIL_MEETING_ENABLED=true
ACADEMIC_AUTO_UPDATE_ENABLED=true
ACADEMIC_AUTO_UPDATE_CRON=5 0 * * *

# Frontend (Next.js build-time)
NEXT_PUBLIC_API_URL=http://119.59.124.67/api
