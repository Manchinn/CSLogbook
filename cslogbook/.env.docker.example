# CSLogbook — Local Development .env template (for docker-compose.yml)
# ---------------------------------------------------------------------
# Copy ไฟล์นี้เป็น .env.docker:
#   cp .env.docker.example .env.docker
#
# จากนั้นรัน:
#   docker compose --env-file .env.docker up -d
#
# NOTE: ใช้ `.env.docker` (ไม่ใช่ `.env`) เพื่อเลี่ยงการชนกับไฟล์ `.env`
# ที่อาจมีค่า production-specific (เช่น DB_USER=root) ซึ่งจะทำให้
# MySQL container boot ไม่ขึ้น (mysql image ห้ามสร้าง user ชื่อ root)
#
# ไฟล์นี้ใช้โดย `docker-compose.yml` (MySQL + Adminer) **เท่านั้น**
# Backend / Frontend อ่าน env จากไฟล์แยก:
#   - backend/.env.development
#   - frontend-next/.env.local

# ===== MySQL (ใน Docker container) =====
MYSQL_ROOT_PASSWORD=rootpass
DB_NAME=cslogbook_prod
DB_USER=cslogbook
DB_PASSWORD=devpass

# ===== Port mapping (host:container) =====
# 3307 เพื่อเลี่ยง conflict กับ MySQL80 (Windows service) ที่อาจติดตั้งอยู่
# ถ้าเครื่องไม่มี MySQL80 → เปลี่ยนเป็น 3306 ได้
DB_PORT_HOST=3307
ADMINER_PORT=8080
