# Database Configuration
DB_HOST='127.0.0.1'
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=cslogbook

# JWT Configuration
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=1d

# ===== EMAIL CONFIGURATION =====
# Provider Options: gmail (Production - Gmail API + OAuth2), ethereal (Testing), console (Debug)
EMAIL_PROVIDER=console
EMAIL_SENDER=your-email@gmail.com

# ----- Gmail API Configuration (ใช้เมื่อ EMAIL_PROVIDER=gmail) -----
# สร้าง OAuth2 credentials ที่ Google Cloud Console
# ดูวิธีตั้งค่าที่: https://developers.google.com/gmail/api/quickstart
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
GMAIL_USER_EMAIL=your-email@gmail.com
ACADEMIC_AUTO_UPDATE_ENABLED=false
# ACADEMIC_AUTO_UPDATE_CRON=5 0 * * * #ทุกๆวันเวลา 00:05 น.
ACADEMIC_AUTO_UPDATE_CRON=*/1 * * * *  #ทุกๆวิลา 1 นาที (สำหรับทดสอบ)


# Server Configuration
PORT=5000
BASE_URL=http://localhost:5000
NODE_ENV=development
API_PREFIX=/api

# Single canonical URL — ใช้สำหรับ SSO redirect และ email links เท่านั้น
FRONTEND_URL=http://localhost:3000

# Comma-separated list — CORS + Socket.io allow-list (Express + WebSocket)
# Production example: ALLOWED_ORIGINS=https://cslogbook.me,https://www.cslogbook.me
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

UPLOAD_DIR=uploads/                
MAX_FILE_SIZE=5242880
